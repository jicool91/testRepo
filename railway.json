{
  "name": "poizon-bot",
  "description": "Poizon товары модерация Telegram канал",
  "stack": "container",
  "env": {
    "POIZON_BOT_TOKEN": {
      "description": "Telegram bot token",
      "required": true
    },
    "POIZON_ADMIN_ID": {
      "description": "Telegram ID админа",
      "required": true
    },
    "POIZON_CHANNEL_ID": {
      "description": "ID канала для постов",
      "required": true
    },
    "POIZON_INTERVAL_MIN": {
      "description": "Интервал модерации (минуты)",
      "value": "10",
      "required": false
    },
    "POIZON_CHECK_INTERVAL_H": {
      "description": "Интервал проверки цен опубликованных товаров (часы)",
      "value": "6",
      "required": false
    },
    "POIZON_PRICE_DROP_PCT": {
      "description": "Порог снижения цены для алерта (проценты)",
      "value": "10",
      "required": false
    },
    "POIZON_PRICE_RISE_PCT": {
      "description": "Порог роста цены для алерта (проценты)",
      "value": "5",
      "required": false
    },
    "POIZON_CLIENT_SECRET": {
      "description": "Poizon API secret_key (опционально)",
      "required": false
    }
  }
}
